import 'package:pinpoint/model/user/user_detail_dto.dart';
import 'package:pinpoint/model/user/user_list_dto.dart';
import 'package:pinpoint/model/user/update_user_dto.dart'; 
import 'package:pinpoint/service/user_api_service.dart';  
 
class UserRepository {
  final UserApiService _apiService;

  UserRepository(this._apiService);

  /// Fetches a list of all users for a given institute or admin ID.
  Future<List<UserListDto>> getAllUsers(String instituteOrAdminId) async {
    try {
      return await _apiService.getAllUsers(instituteOrAdminId);
    } catch (e) {
      print("Error fetching all users: $e");
      rethrow;
    }
  }

  /// Fetches the detailed information for a single user by their ID.
  Future<UserDetailDto> getUserById(String userId) async {
    try {
      return await _apiService.getUserById(userId);
    } catch (e) {
      print("Error fetching user detail for ID $userId: $e");
      rethrow;
    }
  }

  /// Updates a user's information on the server.
  Future<void> updateUser(String userId, UpdateUserDto updatedUser) async {
    try {
      // Assuming your DTO has a toJson() method
      await _apiService.updateUser(userId, updatedUser.toJson());
    } catch (e) {
      print("Error updating user for ID $userId: $e");
      rethrow;
    }
  }

  /// Deletes a user from the server.
  Future<void> deleteUser(String userId) async {
    try {
      await _apiService.deleteUser(userId);
    } catch (e) {
      print("Error deleting user for ID $userId: $e");
      rethrow;
    }
  }
}
